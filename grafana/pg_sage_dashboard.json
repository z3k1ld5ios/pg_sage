    {
      "type": "row",
      "id": 101,
      "title": "Connection & Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Active Connections Over Time",
      "description": "Number of connections by state from pg_stat_activity",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_connections_total{state=\"active\"}",
          "legendFormat": "Active"
        },
        {
          "refId": "B",
          "expr": "pg_sage_connections_total{state=\"idle\"}",
          "legendFormat": "Idle"
        },
        {
          "refId": "C",
          "expr": "pg_sage_connections_total{state=\"idle in transaction\"}",
          "legendFormat": "Idle in Transaction"
        },
        {
          "refId": "D",
          "expr": "pg_sage_max_connections",
          "legendFormat": "Max Connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max Connections" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Cache Hit Ratio Over Time",
      "description": "Buffer cache hit ratio (higher is better, target > 0.99)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_cache_hit_ratio",
          "legendFormat": "Cache Hit Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "area" }
          },
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "min"] }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Transactions Per Second",
      "description": "Rate of committed and rolled back transactions",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(pg_sage_xact_commit_total[5m])",
          "legendFormat": "Commits/s"
        },
        {
          "refId": "B",
          "expr": "rate(pg_sage_xact_rollback_total[5m])",
          "legendFormat": "Rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rollbacks/s" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Findings",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "id": 20,
      "type": "table",
      "title": "Current Findings by Severity",
      "description": "Table of open findings grouped by severity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_findings_total",
          "legendFormat": "{{severity}}",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Count" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 1 },
                  { "color": "orange", "value": 3 },
                  { "color": "red", "value": 5 }
                ]
              }}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ["Value"]
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "severity": "Severity",
              "Value": "Count"
            }
          }
        }
      ]
    },
    {
      "id": 21,
      "type": "barchart",
      "title": "Findings by Severity",
