    {
      "id": 5,
      "type": "stat",
      "title": "Circuit Breaker - DB",
      "description": "Database circuit breaker state (0=closed/healthy, 1=open/tripped)",
      "gridPos": { "h": 4, "w": 3, "x": 16, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_circuit_breaker_state{breaker=\"db\"}",
          "legendFormat": "DB",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red", "index": 1 } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Circuit Breaker - LLM",
      "description": "LLM circuit breaker state (0=closed/healthy, 1=open/tripped)",
      "gridPos": { "h": 4, "w": 3, "x": 19, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_circuit_breaker_state{breaker=\"llm\"}",
