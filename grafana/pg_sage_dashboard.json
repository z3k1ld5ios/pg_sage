      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_findings_total{severity=\"info\"}",
          "legendFormat": "Info",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
