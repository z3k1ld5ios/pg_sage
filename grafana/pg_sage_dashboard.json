        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Database Size",
      "description": "Current database size",
      "gridPos": { "h": 4, "w": 2, "x": 22, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_sage_database_size_bytes",
          "legendFormat": "Size",
          "instant": true
        }
